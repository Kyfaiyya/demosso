{
  "realm": "sso-demo",
  "displayName": "SSO Demo",
  "loginTheme": "sso-demo",
  "enabled": true,
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 300,
  "ssoSessionMaxLifespan": 36000,

  "browserSecurityHeaders": {
    "xFrameOptions": "",
    "contentSecurityPolicy": "frame-src 'self'; frame-ancestors 'self' http://localhost:8000; object-src 'none';",
    "xContentTypeOptions": "nosniff",
    "xRobotsTag": "none",
    "xXSSProtection": "1; mode=block",
    "strictTransportSecurity": "max-age=31536000; includeSubDomains"
  },

  "clients": [
    {
      "clientId": "frontend-app",
      "name": "Frontend React App",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:3000",
        "http://localhost:3001/*",
        "http://localhost:3001",
        "http://localhost:3002/*",
        "http://localhost:3002",
        "http://localhost:8000/*",
        "http://localhost:8000"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:3001",
        "http://localhost:3002",
        "http://localhost:8000"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "nik",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "nik",
            "claim.name": "nik",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "backend-api",
      "name": "Backend API Service",
      "enabled": true,
      "publicClient": false,
      "secret": "backend-secret-1234",
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect"
    }
  ],

  "roles": {
    "realm": [
      { "name": "superadmin",         "description": "Super Administrator — akses penuh semua layanan" },
      { "name": "admin-dukcapil",     "description": "Administrator Dukcapil (App 1)" },
      { "name": "admin-kominfo",      "description": "Administrator Kominfo (App 2)" },
      { "name": "admin-pendidikan",   "description": "Administrator Layanan Pendidikan (App 3)" },
      { "name": "app-user",           "description": "Pengguna biasa" }
    ]
  },

  "groups": [
    {
      "name": "Superadmin",
      "realmRoles": ["superadmin", "admin-dukcapil", "admin-kominfo", "admin-pendidikan"]
    },
    {
      "name": "Admin Dukcapil",
      "realmRoles": ["admin-dukcapil"]
    },
    {
      "name": "Admin Kominfo",
      "realmRoles": ["admin-kominfo"]
    },
    {
      "name": "Admin Pendidikan",
      "realmRoles": ["admin-pendidikan"]
    }
  ],

  "users": [
    {
      "id": "aaaa1111-1111-1111-1111-111111111111",
      "username": "admin_dukcapil",
      "email": "admin_dukcapil@sso.local",
      "firstName": "Admin",
      "lastName": "Dukcapil",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "admin123", "temporary": false }],
      "groups": ["Admin Dukcapil"]
    },
    {
      "id": "bbbb2222-2222-2222-2222-222222222222",
      "username": "admin_kominfo",
      "email": "admin_kominfo@sso.local",
      "firstName": "Admin",
      "lastName": "Kominfo",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "admin123", "temporary": false }],
      "groups": ["Admin Kominfo"]
    },
    {
      "id": "cccc3333-3333-3333-3333-333333333333",
      "username": "admin_pendidikan",
      "email": "admin_pendidikan@sso.local",
      "firstName": "Admin",
      "lastName": "Pendidikan",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "admin123", "temporary": false }],
      "groups": ["Admin Pendidikan"]
    },
    {
      "username": "superadmin",
      "email": "superadmin@sso.local",
      "firstName": "Super",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "super123", "temporary": false }],
      "groups": ["Superadmin"]
    },
    {
      "username": "1234567890123456",
      "email": "budi@sso.local",
      "firstName": "Budi",
      "lastName": "Santoso",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "budi123", "temporary": false }]
    }
  ],

  "defaultRoles": ["app-user"]
}
